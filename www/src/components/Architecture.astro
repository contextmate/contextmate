---

<section id="architecture" class="py-24 px-6 relative overflow-hidden">
  <h2 class="font-mono text-3xl md:text-4xl font-bold text-center mb-4">
    Everything in Sync: like <span class="text-brand-accent">Dropbox for your Claw.</span>
  </h2>
  <p class="text-brand-muted text-center mb-16 max-w-2xl mx-auto">
    Your laptop and every OpenClaw share the same knowledge through an encrypted cloud.
    No one in between can read your data. Not even us.
  </p>

  <!-- Desktop SVG diagram -->
  <div class="hidden md:block max-w-4xl mx-auto relative">
    <svg
      id="sync-diagram"
      viewBox="0 0 800 420"
      xmlns="http://www.w3.org/2000/svg"
      class="w-full h-auto"
    >
      <defs>
        <linearGradient id="card-grad-laptop" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#1a3a5c" />
          <stop offset="100%" stop-color="#162544" />
        </linearGradient>
        <linearGradient id="card-grad-claw" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#2a1a4c" />
          <stop offset="100%" stop-color="#1e1544" />
        </linearGradient>
        <linearGradient id="card-grad-cloud" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#1a2a1a" />
          <stop offset="100%" stop-color="#15201a" />
        </linearGradient>
        <filter id="glow-blue" x="-30%" y="-30%" width="160%" height="160%">
          <feGaussianBlur in="SourceAlpha" stdDeviation="4" result="blur" />
          <feFlood flood-color="#4fc3f7" flood-opacity="0.2" result="color" />
          <feComposite in="color" in2="blur" operator="in" result="glow" />
          <feComposite in="SourceGraphic" in2="glow" operator="over" />
        </filter>
        <filter id="glow-purple" x="-30%" y="-30%" width="160%" height="160%">
          <feGaussianBlur in="SourceAlpha" stdDeviation="4" result="blur" />
          <feFlood flood-color="#8b5cf6" flood-opacity="0.2" result="color" />
          <feComposite in="color" in2="blur" operator="in" result="glow" />
          <feComposite in="SourceGraphic" in2="glow" operator="over" />
        </filter>
        <filter id="glow-green" x="-30%" y="-30%" width="160%" height="160%">
          <feGaussianBlur in="SourceAlpha" stdDeviation="5" result="blur" />
          <feFlood flood-color="#66bb6a" flood-opacity="0.15" result="color" />
          <feComposite in="color" in2="blur" operator="in" result="glow" />
          <feComposite in="SourceGraphic" in2="glow" operator="over" />
        </filter>
      </defs>

      <!-- ============================================ -->
      <!-- CONNECTING PATHS                             -->
      <!-- ============================================ -->

      <!-- Laptop → Cloud -->
      <path class="sync-path" d="M 170 195 C 250 195, 300 195, 340 195"
        stroke="#2a2a4a" stroke-width="2" fill="none" opacity="0.3" />
      <!-- Cloud → Laptop (reverse) -->
      <path class="sync-path sync-path-reverse" d="M 340 205 C 300 205, 250 205, 170 205"
        stroke="#2a2a4a" stroke-width="2" fill="none" opacity="0.3" />

      <!-- Cloud → OpenClaw #1 -->
      <path class="sync-path" d="M 460 170 C 510 145, 545 110, 590 95"
        stroke="#2a2a4a" stroke-width="2" fill="none" opacity="0.3" />
      <!-- OpenClaw #1 → Cloud (reverse) -->
      <path class="sync-path sync-path-reverse" d="M 590 100 C 545 115, 510 150, 460 175"
        stroke="#2a2a4a" stroke-width="2" fill="none" opacity="0.3" />

      <!-- Cloud → OpenClaw #2 -->
      <path class="sync-path" d="M 460 195 C 500 195, 540 195, 590 195"
        stroke="#2a2a4a" stroke-width="2" fill="none" opacity="0.3" />
      <!-- OpenClaw #2 → Cloud (reverse) -->
      <path class="sync-path sync-path-reverse" d="M 590 205 C 540 205, 500 205, 460 205"
        stroke="#2a2a4a" stroke-width="2" fill="none" opacity="0.3" />

      <!-- Cloud → OpenClaw #3 -->
      <path class="sync-path" d="M 460 230 C 510 255, 545 290, 590 305"
        stroke="#2a2a4a" stroke-width="2" fill="none" opacity="0.3" />
      <!-- OpenClaw #3 → Cloud (reverse) -->
      <path class="sync-path sync-path-reverse" d="M 590 310 C 545 295, 510 260, 460 235"
        stroke="#2a2a4a" stroke-width="2" fill="none" opacity="0.3" />

      <!-- Path labels -->
      <text x="255" y="186" fill="#66bb6a" font-size="10" font-family="var(--font-mono)" text-anchor="middle" opacity="0.7">encrypted</text>
      <text x="530" y="140" fill="#66bb6a" font-size="10" font-family="var(--font-mono)" text-anchor="middle" opacity="0.7">encrypted</text>

      <!-- ============================================ -->
      <!-- YOUR LAPTOP (left)                           -->
      <!-- ============================================ -->

      <g class="sync-node">
        <rect x="20" y="150" width="150" height="100" rx="16" fill="url(#card-grad-laptop)" stroke="rgba(79,195,247,0.25)" stroke-width="1.5" filter="url(#glow-blue)" />
        <!-- Laptop icon -->
        <g transform="translate(55, 168)">
          <rect x="0" y="0" width="40" height="26" rx="4" stroke="#4fc3f7" stroke-width="1.5" fill="rgba(79,195,247,0.08)" />
          <rect x="6" y="4" width="28" height="16" rx="1" fill="rgba(79,195,247,0.12)" />
          <path d="M-4 30h48" stroke="#4fc3f7" stroke-width="1.5" stroke-linecap="round" />
        </g>
        <text x="95" y="220" fill="#e0e0e0" font-size="13" font-family="var(--font-sans)" text-anchor="middle" font-weight="600">Your Laptop</text>
        <text x="95" y="237" fill="#4fc3f7" font-size="9.5" font-family="var(--font-mono)" text-anchor="middle" opacity="0.7">edit + configure</text>
      </g>

      <!-- ============================================ -->
      <!-- ENCRYPTED CLOUD (center)                     -->
      <!-- ============================================ -->

      <g class="sync-node">
        <rect x="340" y="140" width="120" height="120" rx="20" fill="url(#card-grad-cloud)" stroke="rgba(102,187,106,0.25)" stroke-width="1.5" filter="url(#glow-green)" />
        <!-- Lock icon -->
        <g transform="translate(376, 160)">
          <rect x="0" y="14" width="28" height="22" rx="4" fill="rgba(102,187,106,0.1)" stroke="#66bb6a" stroke-width="1.5" />
          <path d="M5 14V10a9 9 0 0118 0v4" stroke="#66bb6a" stroke-width="1.5" fill="none" stroke-linecap="round" />
          <circle cx="14" cy="26" r="3" fill="#66bb6a" opacity="0.5" />
          <rect x="13" y="26" width="2" height="5" rx="0.5" fill="#66bb6a" opacity="0.5" />
        </g>
        <text x="400" y="230" fill="#e0e0e0" font-size="12" font-family="var(--font-sans)" text-anchor="middle" font-weight="600">Encrypted</text>
        <text x="400" y="246" fill="#66bb6a" font-size="9.5" font-family="var(--font-mono)" text-anchor="middle" opacity="0.7">zero-knowledge</text>
      </g>

      <!-- ============================================ -->
      <!-- OPENCLAW DEVICES (right)                     -->
      <!-- ============================================ -->

      <!-- OpenClaw #1 -->
      <g class="sync-node">
        <rect x="590" y="55" width="195" height="70" rx="14" fill="url(#card-grad-claw)" stroke="rgba(139,92,246,0.25)" stroke-width="1.5" filter="url(#glow-purple)" />
        <g transform="translate(605, 70)">
          <circle cx="5" cy="3" r="3.5" fill="rgba(139,92,246,0.3)" />
          <circle cx="14" cy="1.5" r="3.5" fill="rgba(139,92,246,0.3)" />
          <circle cx="22" cy="4" r="3.5" fill="rgba(139,92,246,0.3)" />
          <ellipse cx="13.5" cy="14" rx="10" ry="8" fill="rgba(139,92,246,0.15)" stroke="#8b5cf6" stroke-width="1" />
        </g>
        <text x="670" y="88" fill="#e0e0e0" font-size="12" font-family="var(--font-sans)" dominant-baseline="middle" font-weight="500">OpenClaw #1</text>
        <text x="670" y="106" fill="#8b5cf6" font-size="9" font-family="var(--font-mono)" dominant-baseline="middle" opacity="0.7">kitchen robot</text>
      </g>

      <!-- OpenClaw #2 -->
      <g class="sync-node">
        <rect x="590" y="165" width="195" height="70" rx="14" fill="url(#card-grad-claw)" stroke="rgba(139,92,246,0.25)" stroke-width="1.5" filter="url(#glow-purple)" />
        <g transform="translate(605, 180)">
          <circle cx="5" cy="3" r="3.5" fill="rgba(139,92,246,0.3)" />
          <circle cx="14" cy="1.5" r="3.5" fill="rgba(139,92,246,0.3)" />
          <circle cx="22" cy="4" r="3.5" fill="rgba(139,92,246,0.3)" />
          <ellipse cx="13.5" cy="14" rx="10" ry="8" fill="rgba(139,92,246,0.15)" stroke="#8b5cf6" stroke-width="1" />
        </g>
        <text x="670" y="198" fill="#e0e0e0" font-size="12" font-family="var(--font-sans)" dominant-baseline="middle" font-weight="500">OpenClaw #2</text>
        <text x="670" y="216" fill="#8b5cf6" font-size="9" font-family="var(--font-mono)" dominant-baseline="middle" opacity="0.7">workshop robot</text>
      </g>

      <!-- OpenClaw #3 -->
      <g class="sync-node">
        <rect x="590" y="275" width="195" height="70" rx="14" fill="url(#card-grad-claw)" stroke="rgba(139,92,246,0.25)" stroke-width="1.5" filter="url(#glow-purple)" />
        <g transform="translate(605, 290)">
          <circle cx="5" cy="3" r="3.5" fill="rgba(139,92,246,0.3)" />
          <circle cx="14" cy="1.5" r="3.5" fill="rgba(139,92,246,0.3)" />
          <circle cx="22" cy="4" r="3.5" fill="rgba(139,92,246,0.3)" />
          <ellipse cx="13.5" cy="14" rx="10" ry="8" fill="rgba(139,92,246,0.15)" stroke="#8b5cf6" stroke-width="1" />
        </g>
        <text x="670" y="308" fill="#e0e0e0" font-size="12" font-family="var(--font-sans)" dominant-baseline="middle" font-weight="500">OpenClaw #3</text>
        <text x="670" y="326" fill="#8b5cf6" font-size="9" font-family="var(--font-mono)" dominant-baseline="middle" opacity="0.7">office robot</text>
      </g>

      <!-- ============================================ -->
      <!-- BOTTOM: What syncs                           -->
      <!-- ============================================ -->

      <g transform="translate(200, 380)">
        <text x="0" y="0" fill="#888888" font-size="10.5" font-family="var(--font-sans)">
          What syncs:
        </text>
        <text x="80" y="0" fill="#e0e0e0" font-size="10.5" font-family="var(--font-mono)">
          identity  ·  memory  ·  skills  ·  rules  ·  shared documents
        </text>
      </g>
    </svg>
  </div>

  <!-- ============================================ -->
  <!-- MOBILE: Simplified vertical card layout      -->
  <!-- ============================================ -->
  <div class="md:hidden flex flex-col items-center gap-5 max-w-sm mx-auto">

    <!-- Your Laptop -->
    <div class="w-full rounded-2xl p-5 relative overflow-hidden" style="background: linear-gradient(135deg, #1a3a5c, #162544); border: 1px solid rgba(79,195,247,0.2);">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="2" width="18" height="12" rx="2" stroke="#4fc3f7" stroke-width="1.2" fill="rgba(79,195,247,0.1)" />
            <path d="M0 15h20" stroke="#4fc3f7" stroke-width="1.2" stroke-linecap="round" />
          </svg>
        </div>
        <div>
          <p class="text-sm text-white font-semibold">Your Laptop</p>
          <p class="text-xs text-white/50 font-mono">edit + configure</p>
        </div>
      </div>
    </div>

    <!-- Bidirectional arrow: encrypted -->
    <div class="flex flex-col items-center gap-1">
      <svg width="24" height="32" viewBox="0 0 24 32" fill="none">
        <path d="M8 8v20M3 24l5 6 5-6" stroke="#66bb6a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M16 24V4M11 8l5-6 5 6" stroke="#66bb6a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="text-emerald-400 font-mono text-xs tracking-wide">encrypted sync</span>
    </div>

    <!-- Encrypted Cloud -->
    <div class="w-full rounded-2xl p-5 relative overflow-hidden" style="background: linear-gradient(135deg, #1a2a1a, #15201a); border: 1px solid rgba(102,187,106,0.2);">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-emerald-500/15 flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="4" y="9" width="12" height="9" rx="2" stroke="#66bb6a" stroke-width="1.2" fill="rgba(102,187,106,0.1)" />
            <path d="M6 9V7a4 4 0 018 0v2" stroke="#66bb6a" stroke-width="1.2" fill="none" stroke-linecap="round" />
            <circle cx="10" cy="14" r="1.5" fill="#66bb6a" opacity="0.5" />
          </svg>
        </div>
        <div>
          <p class="text-sm text-white font-semibold">Encrypted Cloud</p>
          <p class="text-xs text-emerald-400/70 font-mono">zero-knowledge</p>
        </div>
      </div>
    </div>

    <!-- Bidirectional arrow: encrypted -->
    <div class="flex flex-col items-center gap-1">
      <svg width="24" height="32" viewBox="0 0 24 32" fill="none">
        <path d="M8 8v20M3 24l5 6 5-6" stroke="#66bb6a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M16 24V4M11 8l5-6 5 6" stroke="#66bb6a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="text-emerald-400 font-mono text-xs tracking-wide">encrypted sync</span>
    </div>

    <!-- OpenClaw devices -->
    <div class="w-full space-y-3">
      <div class="rounded-2xl p-4 flex items-center gap-3" style="background: linear-gradient(135deg, #2a1a4c, #1e1544); border: 1px solid rgba(139,92,246,0.2);">
        <div class="w-10 h-10 rounded-xl bg-purple-500/15 flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="5" cy="5" r="2.5" fill="rgba(139,92,246,0.4)" />
            <circle cx="11" cy="4" r="2.5" fill="rgba(139,92,246,0.4)" />
            <circle cx="16" cy="6" r="2.5" fill="rgba(139,92,246,0.4)" />
            <ellipse cx="10" cy="13" rx="6" ry="5" fill="rgba(139,92,246,0.15)" stroke="#8b5cf6" stroke-width="1" />
          </svg>
        </div>
        <div>
          <p class="text-sm text-white font-medium">OpenClaw #1</p>
          <p class="text-xs text-purple-400/70 font-mono">kitchen robot</p>
        </div>
      </div>
      <div class="rounded-2xl p-4 flex items-center gap-3" style="background: linear-gradient(135deg, #2a1a4c, #1e1544); border: 1px solid rgba(139,92,246,0.2);">
        <div class="w-10 h-10 rounded-xl bg-purple-500/15 flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="5" cy="5" r="2.5" fill="rgba(139,92,246,0.4)" />
            <circle cx="11" cy="4" r="2.5" fill="rgba(139,92,246,0.4)" />
            <circle cx="16" cy="6" r="2.5" fill="rgba(139,92,246,0.4)" />
            <ellipse cx="10" cy="13" rx="6" ry="5" fill="rgba(139,92,246,0.15)" stroke="#8b5cf6" stroke-width="1" />
          </svg>
        </div>
        <div>
          <p class="text-sm text-white font-medium">OpenClaw #2</p>
          <p class="text-xs text-purple-400/70 font-mono">workshop robot</p>
        </div>
      </div>
      <div class="rounded-2xl p-4 flex items-center gap-3" style="background: linear-gradient(135deg, #2a1a4c, #1e1544); border: 1px solid rgba(139,92,246,0.2);">
        <div class="w-10 h-10 rounded-xl bg-purple-500/15 flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="5" cy="5" r="2.5" fill="rgba(139,92,246,0.4)" />
            <circle cx="11" cy="4" r="2.5" fill="rgba(139,92,246,0.4)" />
            <circle cx="16" cy="6" r="2.5" fill="rgba(139,92,246,0.4)" />
            <ellipse cx="10" cy="13" rx="6" ry="5" fill="rgba(139,92,246,0.15)" stroke="#8b5cf6" stroke-width="1" />
          </svg>
        </div>
        <div>
          <p class="text-sm text-white font-medium">OpenClaw #3</p>
          <p class="text-xs text-purple-400/70 font-mono">office robot</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .sync-node {
    transition: transform 0.2s ease;
  }

  .sync-path {
    transition: opacity 0.3s ease, stroke 0.3s ease;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const svg = document.getElementById('sync-diagram');
    if (!svg) return;

    const paths = svg.querySelectorAll('.sync-path');
    const particles: {
      el: SVGCircleElement;
      path: SVGPathElement;
      totalLength: number;
      progress: number;
      speed: number;
    }[] = [];

    let isVisible = false;
    let animating = false;

    const observer = new IntersectionObserver(
      (entries) => {
        isVisible = entries[0]!.isIntersecting;
        if (isVisible && !animating) animate();
      },
      { threshold: 0.15 }
    );
    observer.observe(svg);

    // Create particles for each path
    paths.forEach((path) => {
      const svgPath = path as SVGPathElement;
      const totalLength = svgPath.getTotalLength();

      for (let j = 0; j < 1; j++) {
        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('r', '3.5');
        circle.setAttribute('fill', '#66bb6a');
        circle.style.filter = 'drop-shadow(0 0 5px rgba(102,187,106,0.7))';
        circle.style.pointerEvents = 'none';
        svg.appendChild(circle);

        particles.push({
          el: circle,
          path: svgPath,
          totalLength,
          progress: j * 0.5 + Math.random() * 0.2,
          speed: 0.002 + Math.random() * 0.001,
        });
      }
    });

    function animate() {
      if (!isVisible) {
        animating = false;
        return;
      }
      animating = true;

      particles.forEach((p) => {
        p.progress += p.speed;
        if (p.progress > 1) p.progress -= 1;

        const point = p.path.getPointAtLength(p.progress * p.totalLength);
        p.el.setAttribute('cx', String(point.x));
        p.el.setAttribute('cy', String(point.y));
      });

      requestAnimationFrame(animate);
    }
  });
</script>
