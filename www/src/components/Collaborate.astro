---

---

<section class="py-24 px-6 bg-brand-deep/50">
  <div class="max-w-4xl mx-auto">
    <!-- Section heading -->
    <div class="text-center mb-16">
      <h2 class="font-mono text-3xl md:text-4xl font-bold mb-6">
        Sync knowledge and collaborate on docs<br />
        <span class="text-brand-accent">with your Claw.</span>
      </h2>
      <p class="text-brand-muted text-lg max-w-2xl mx-auto">
        ContextMate keeps your OpenClaw's brain on your laptop. Edit its configuration, share files back and forth, and keep multiple robots in sync.
      </p>
    </div>

    <!-- Two use cases -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-14">
      <!-- Use case 1: Robot ↔ Laptop -->
      <div class="use-case-card use-case-card-1 rounded-2xl p-8 relative overflow-hidden">
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-12 h-12 rounded-xl bg-white/10 backdrop-blur flex items-center justify-center">
              <svg viewBox="0 0 24 24" class="w-6 h-6">
                <path d="M4 6h10v7H4z" fill="rgba(255,255,255,0.15)" stroke="white" stroke-width="1.3" rx="1.5" />
                <path d="M2 14h14" stroke="white" stroke-width="1.3" stroke-linecap="round" />
                <path d="M16 9h4" stroke="white" stroke-width="1" stroke-linecap="round" stroke-dasharray="1.5 1.5" opacity="0.5" />
                <rect x="18" y="5" width="4" height="8" rx="1" stroke="white" stroke-width="1.2" fill="rgba(255,255,255,0.1)" />
              </svg>
            </div>
            <h3 class="font-mono font-bold text-xl text-white">OpenClaw ↔ Your Laptop</h3>
          </div>
          <p class="text-white/70 text-sm leading-relaxed mb-5">
            Define who your robot is. Edit its identity, memory, and skills from your laptop. When your OpenClaw creates something, like a presentation or a report, it shows up in a sealed folder on your machine. Your robot never sees anything else.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="font-mono text-xs text-white/90 bg-white/10 backdrop-blur rounded-lg px-3 py-1.5">IDENTITY.md</span>
            <span class="font-mono text-xs text-white/90 bg-white/10 backdrop-blur rounded-lg px-3 py-1.5">MEMORY.md</span>
            <span class="font-mono text-xs text-white/90 bg-white/10 backdrop-blur rounded-lg px-3 py-1.5">AGENTS.md</span>
            <span class="font-mono text-xs text-white/90 bg-white/10 backdrop-blur rounded-lg px-3 py-1.5">shared-docs/*</span>
          </div>
        </div>
      </div>

      <!-- Use case 2: Multi-device -->
      <div class="use-case-card use-case-card-2 rounded-2xl p-8 relative overflow-hidden">
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-12 h-12 rounded-xl bg-white/10 backdrop-blur flex items-center justify-center">
              <svg viewBox="0 0 24 24" class="w-6 h-6">
                <circle cx="7" cy="8" r="3" fill="rgba(255,255,255,0.15)" stroke="white" stroke-width="1.2" />
                <circle cx="17" cy="8" r="3" fill="rgba(255,255,255,0.15)" stroke="white" stroke-width="1.2" />
                <circle cx="12" cy="18" r="3" fill="rgba(255,255,255,0.15)" stroke="white" stroke-width="1.2" />
                <path d="M9.5 9.5l2 5.5M14.5 9.5l-2 5.5M9 7h6" stroke="white" stroke-width="0.8" opacity="0.4" />
              </svg>
            </div>
            <h3 class="font-mono font-bold text-xl text-white">OpenClaw ↔ OpenClaw</h3>
          </div>
          <p class="text-white/70 text-sm leading-relaxed mb-5">
            Running multiple OpenClaw devices? Keep their knowledge in sync. Skills, memories, and rules stay consistent across your entire fleet, automatically. Teach one robot, and all of them learn.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="font-mono text-xs text-white/90 bg-white/10 backdrop-blur rounded-lg px-3 py-1.5">skills/*.md</span>
            <span class="font-mono text-xs text-white/90 bg-white/10 backdrop-blur rounded-lg px-3 py-1.5">daily-log.md</span>
            <span class="font-mono text-xs text-white/90 bg-white/10 backdrop-blur rounded-lg px-3 py-1.5">rules/*.md</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Isolation callout -->
    <div class="isolation-callout rounded-2xl p-6 max-w-2xl mx-auto">
      <div class="flex gap-4 items-start">
        <div class="w-10 h-10 rounded-xl bg-emerald-500/20 flex items-center justify-center shrink-0">
          <svg viewBox="0 0 24 24" class="w-5 h-5">
            <path d="M12 2L4 7v6c0 5.5 3.4 10.7 8 12 4.6-1.3 8-6.5 8-12V7l-8-5z" fill="rgba(102,187,106,0.15)" stroke="#66bb6a" stroke-width="1.5"/>
            <path d="M9 12l2 2 4-4" fill="none" stroke="#66bb6a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="text-brand-text font-semibold text-sm mb-1">Sealed off by design</p>
          <p class="text-brand-muted text-sm leading-relaxed">
            OpenClaw never sees the rest of your machine. It only has access to a specific synced folder. Your files, your projects, your data: completely invisible to the robot.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .use-case-card-1 {
    background: linear-gradient(135deg, #1a3a5c 0%, #0d2847 40%, #162544 100%);
    border: 1px solid rgba(79, 195, 247, 0.2);
  }

  .use-case-card-1::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -30%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(79, 195, 247, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .use-case-card-2 {
    background: linear-gradient(135deg, #2a1a4c 0%, #1a1040 40%, #1e1544 100%);
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .use-case-card-2::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -30%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .use-case-card {
    transition: border-color 0.3s ease, transform 0.2s ease;
  }

  .use-case-card:hover {
    transform: translateY(-2px);
  }

  .use-case-card-1:hover {
    border-color: rgba(79, 195, 247, 0.4);
  }

  .use-case-card-2:hover {
    border-color: rgba(139, 92, 246, 0.4);
  }

  .isolation-callout {
    background: linear-gradient(135deg, rgba(102, 187, 106, 0.05) 0%, rgba(15, 23, 41, 0.8) 100%);
    border: 1px solid rgba(102, 187, 106, 0.15);
  }
</style>
