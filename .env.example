# ContextMate Server Environment Variables

# JWT signing secret. Required for multi-instance deployments.
# If omitted, a random secret is auto-generated and persisted to data/jwt-secret.txt.
JWT_SECRET=

# Server port (default: 3000)
PORT=3000

# Invite code for registration. If set, new users must provide this code
# to create an account. Leave blank for open registration.
INVITE_CODE=
